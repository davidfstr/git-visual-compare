#!/usr/bin/env bash
# Run a command inside a macOS Seatbelt sandbox tailored for gvc development.
# Usage: ./sandbox <command> [args...]
# Example: ./sandbox poetry run pytest

# If an error occurs abort the script
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Write Seatbelt sandbox policy to temp file
SBPL="$(mktemp /tmp/gvc-sandbox.XXXXXX)"
trap 'rm -f "$SBPL"' EXIT
cat > "$SBPL" << SBPL
(version 1)

; --- Mach IPC ---
; Must appear before (deny default). Covers all com.apple.* services including
; the dynamic/versioned ones WKWebView needs for JS evaluation callbacks.
(allow mach-lookup
  (global-name-regex #"^com\\.apple\\."))

; --- Deny everything else by default ---
(deny default)

; --- Process ---
(allow process-exec)
(allow process-fork)
; NOTE: Only needed by 1 test: test_when_gvc_run_in_terminal_given_no_gui_running_then_starts_gui_and_opens_new_diff_window
;       which already fails to execute inside this sandbox for other reasons
;(allow lsopen)
(allow process-info* (target same-sandbox))
(allow signal (target same-sandbox))
(allow mach-priv-task-port (target same-sandbox))

; --- Preferences / IPC primitives ---
(allow user-preference-read)
(allow ipc-posix-shm)
(allow ipc-posix-sem)

; --- Kernel / IOKit ---
(allow iokit-open)
(allow sysctl-read)

; --- Sockets ---
; AF_SYSTEM (routing socket — needed by network stack init)
(allow system-socket
  (require-all (socket-domain AF_SYSTEM) (socket-protocol 2)))
; AF_UNIX (gvc uses Unix sockets for CLI→GUI IPC and test harness control)
(allow system-socket (socket-domain AF_UNIX))
(allow network-bind    (local unix-socket (path-regex #"^/private/(tmp|var/folders)/")))
(allow network-outbound (remote unix-socket (path-regex #"^/private/(tmp|var/folders)/")))
; Localhost TCP (used by WKWebView's networking process internally)
(allow network-bind    (local ip "localhost:*"))
(allow network-outbound (remote ip "localhost:*"))

; --- WebKit child-process bootstrap ---
; WKWebView spawns GPU, WebContent, and Networking helper processes.
; These extensions let the parent grant them sandbox capabilities.
(allow mach-issue-extension
  (extension-class "com.apple.webkit.extension.mach"))
(allow generic-issue-extension
  (extension-class "com.apple.webkit.mach-bootstrap"))
(allow mach-register
  (global-name-regex #"^com\\.apple\\.WebKit\\."))
(allow mach-register
  (local-name "com.apple.axserver")
  (local-name "com.apple.tsm.portname")
  (local-name "com.apple.coredrag"))

; --- HID (text selection in WKWebView) ---
(allow hid-control)

; --- File extensions for WebKit sandboxed sub-processes ---
(allow file-issue-extension
  (extension-class "com.apple.app-sandbox.read")
  (extension-class "com.apple.app-sandbox.read-write"))

; --- File reads (allowlist only; intentionally excludes most of $HOME) ---
; Root directory itself (needed by dyld during process startup)
(allow file-read* (literal "/"))
; Standard Unix + macOS system paths
(allow file-read* (subpath "/bin"))
(allow file-read* (subpath "/sbin"))
(allow file-read* (literal "/dev"))         ; directory entry for ls/stat
(allow file-read* (literal "/dev/null"))
(allow file-read* (literal "/dev/stdin"))
(allow file-read* (literal "/dev/stdout"))
(allow file-read* (literal "/dev/stderr"))
(allow file-read* (literal "/dev/urandom"))
(allow file-read* (literal "/dev/random"))
(allow file-read* (literal "/dev/tty"))     ; terminal detection
(allow file-read-metadata (literal "/etc"))       ; symlink — content covered by /private/etc
(allow file-read-metadata (literal "/private"))  ; symlink resolution for /etc /tmp /var
(allow file-read* (subpath "/private/etc"))
(allow file-read-metadata (literal "/private/tmp"))  ; directory stat only
(allow file-read* (path-regex #"^/private/tmp/gvc-"))       ; sandbox policy files + test harness dirs
(allow file-read* (path-regex #"^/private/tmp/tmp[^/]*\.gvc$"))  ; gvc IPC diff temp files
(allow file-read-metadata (literal "/private/var"))  ; stat without directory listing
; /private/var/folders: stat intermediate dirs; full read only under T/ (temp) and C/ (cache)
(allow file-read-metadata
  (literal "/private/var/folders")
  (path-regex #"^/private/var/folders/[^/]+(/[^/]+)?$"))
(allow file-read* (path-regex #"^/private/var/folders/[^/]+/[^/]+/T(/|$)"))
(allow file-read-metadata (literal "/tmp"))       ; symlink — content covered by /private/tmp
(allow file-read-metadata (literal "/var"))       ; symlink — content covered by /private/var/*
(allow file-read-metadata (literal "/System"))    ; stat /System itself (dyld startup)
(allow file-read-metadata (literal "/System/Cryptexes"))
(allow file-read* (subpath "/System/Cryptexes/OS"))
(allow file-read-metadata (literal "/System/Library"))
(allow file-read* (subpath "/System/Library/CoreServices"))
(allow file-read* (subpath "/System/Library/Frameworks"))
(allow file-read* (subpath "/System/Library/PrivateFrameworks"))
(allow file-read-metadata (literal "/System/Volumes"))  ; stat /System/Volumes itself
(allow file-read* (subpath "/System/Volumes/Preboot"))
(allow file-read-metadata (literal "/usr"))   ; directory stat
(allow file-read* (subpath "/usr/bin"))       ; git, python symlinks, etc.
(allow file-read* (subpath "/usr/lib"))       ; system dylibs
(allow file-read* (subpath "/usr/libexec"))   ; helper/XPC processes
(allow file-read* (subpath "/usr/share"))     ; locale, timezone, terminfo
(allow file-read-metadata (literal "/Library"))
(allow file-read-metadata (literal "/Library/Developer"))
(allow file-read* (subpath "/Library/Developer/CommandLineTools"))
(allow file-read-metadata (literal "/Library/Frameworks"))
(allow file-read* (subpath "/Library/Frameworks/Python.framework"))
; stat/lstat on intermediate $HOME path components needed for realpath traversal.
; file-read-metadata allows stat/lstat WITHOUT allowing directory listing.
(allow file-read-metadata
  (literal "/Users")
  (literal "$HOME")
  (literal "$HOME/.local")
  (literal "$HOME/.local/pipx")
  (literal "$HOME/Library")
  (literal "$HOME/Library/Application Support")
  (literal "${SCRIPT_DIR%/*}"))
; User subtrees actually needed
(allow file-read* (subpath "$HOME/Library/Caches/com.apple.python"))  ; Python system cache
(allow file-read* (subpath "$HOME/Library/Caches/org.python.python")) ; Python bytecode cache
(allow file-read* (subpath "$HOME/Library/Caches/pip"))               ; pip package cache
(allow file-read* (subpath "$HOME/Library/Caches/pypoetry"))          ; poetry package cache
(allow file-read* (subpath "$HOME/Library/WebKit/net.dafoster.gvc"))  ; gvc WebKit storage
(allow file-read* (subpath "$HOME/Library/WebKit/org.python.python")) ; Python WebKit storage
(allow file-read* (subpath "$HOME/Library/Application Support/pypoetry")) ; poetry config
(allow file-read* (subpath "$HOME/.local/bin"))        ; poetry symlink
(allow file-read* (subpath "$HOME/.local/pipx/venvs")) ; poetry pipx venv
(allow file-read* (literal "$HOME/.gitconfig"))        ; git reads this on every invocation
; Project source + .venv
(allow file-read* (subpath "$SCRIPT_DIR"))

; --- File writes (restricted) ---
; Temp directories
(allow file-write* (subpath "/private/tmp"))
(allow file-write* (path-regex #"^/private/var/folders/[^/]+/[^/]+/C/"))
; Standard character devices
(allow file-write* (literal "/dev/null"))
(allow file-write* (literal "/dev/stdout"))
(allow file-write* (literal "/dev/stderr"))
; WebKit caches (required for WKWebView JS evaluation to complete)
(allow file-write* (subpath "$HOME/Library/Caches/org.python.python"))
(allow file-write* (subpath "$HOME/Library/WebKit/net.dafoster.gvc"))  ; gvc WebKit storage
(allow file-write* (subpath "$HOME/Library/WebKit/org.python.python")) ; Python WebKit storage
; Project directory (test outputs, .pytest_cache, etc.)
(allow file-write* (subpath "$SCRIPT_DIR"))
SBPL

# Run provided command inside Seatbelt sandbox (via sandbox-exec).
# GVC_SEATBELT_SANDBOX=1 signals to tests that some capabilities are restricted.
exec sandbox-exec -f "$SBPL" env GVC_SEATBELT_SANDBOX=1 "$@"
