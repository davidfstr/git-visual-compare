#!/usr/bin/env bash
# Run a command inside an Agent Safehouse sandbox tailored for gvc.
#
# Usage (run command):
#   ./sandbox poetry run pytest
#   ./sandbox claude --dangerously-skip-permissions
# 
# Usage (output sandbox *.sb profile to stdout)
#   ./sandbox --stdout
#
# This script wraps `safehouse` (https://agent-safehouse.dev/) with the set of
# enables, env-pass entries, and append-profile required for gvc work:
#
#   - --enable=macos-gui
#       gvc opens Cocoa windows; macos-gui covers windowserver/AppKit/etc.
#
#   - --append-profile=./gvc-safehouse-extensions.sb
#       Adds WebKit child-process bootstrap rules, the per-app WebKit storage
#       paths, and tightens network policy to outbound TCP/UDP + localhost +
#       gvc Unix-socket IPC. See the file for details.
#
#   - --env-pass=GVC_SEATBELT_SANDBOX,PATH
#       Forwards GVC_SEATBELT_SANDBOX so the test suite knows it's sandboxed
#       and skips GUI-heavy tests. Forwards PATH so `poetry`, `claude`, etc.
#       resolve to the user's installs (safehouse otherwise sanitizes PATH).
#
# Unlike the legacy ./sandbox-legacy/sandbox script, this wrapper has no
# inner/outer split - it always operates like the former outer mode, which
# is the strict superset needed to run `claude` and is also sufficient for
# `poetry run pytest`.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [[ "$SCRIPT_DIR" == *'"'* ]]; then
    echo "error: SCRIPT_DIR contains a double quote; cannot construct a safe sandbox profile." >&2
    exit 1
fi

# ------------------------------------------------------------------------------
# Pin safehouse binary version

# Hash-pin safehouse so a compromised PATH or a different installed version
# cannot silently change the sandbox policy this script applies. To update
# safehouse, intentionally bump SAFEHOUSE_EXPECTED_VERSION and
# SAFEHOUSE_EXPECTED_SHA256 together after reviewing the new release.
SAFEHOUSE_EXPECTED_VERSION="0.9.0"
SAFEHOUSE_EXPECTED_SHA256="61c2f71ee13ef9089442cb13cf050cc679e767ec48da9771e7d8f8a3eb2a8697"

SAFEHOUSE_PATH="$(command -v safehouse 2>/dev/null || true)"
if [[ -z "$SAFEHOUSE_PATH" ]]; then
    cat >&2 <<EOF
error: safehouse not found on PATH.

Install agent-safehouse $SAFEHOUSE_EXPECTED_VERSION via Homebrew:

  brew tap eugene1g/safehouse
  brew install agent-safehouse@$SAFEHOUSE_EXPECTED_VERSION

See https://agent-safehouse.dev/ for other install options.
EOF
    exit 127
fi
SAFEHOUSE_REAL="$(realpath "$SAFEHOUSE_PATH")"
SAFEHOUSE_ACTUAL_SHA256="$(shasum -a 256 "$SAFEHOUSE_REAL" | awk '{print $1}')"
if [[ "$SAFEHOUSE_ACTUAL_SHA256" != "$SAFEHOUSE_EXPECTED_SHA256" ]]; then
    cat >&2 <<EOF
error: safehouse binary hash mismatch - refusing to run.

  binary:   $SAFEHOUSE_REAL
  expected: sha256:$SAFEHOUSE_EXPECTED_SHA256  (version $SAFEHOUSE_EXPECTED_VERSION)
  actual:   sha256:$SAFEHOUSE_ACTUAL_SHA256

This means one of:
  (1) The installed safehouse is not version $SAFEHOUSE_EXPECTED_VERSION. 
      Reinstall the pinned version (see install instructions in this script's header).
  (2) The 'safehouse' binary on PATH has been replaced with something else.
      Treat this as a possible compromise and investigate before proceeding.

Do NOT run 'safehouse --version' to identify the unknown binary; if it has
been substituted, executing it is exactly what an attacker would want.
EOF
    exit 126
fi

# ------------------------------------------------------------------------------
# Run

if (( $# == 0 )); then
    echo "usage: $0 [--stdout] <command> [args...]" >&2
    exit 2
fi

# Signal to the gvc test suite that some capabilities are restricted.
export GVC_SEATBELT_SANDBOX=1

# Write a preamble profile that defines SCRIPT_DIR so that
# gvc-safehouse-extensions.sb can reference checkout-relative paths portably.
# NOTE: Uses a content-addressed filename: same checkout reuses the same file;
#       different checkouts get distinct names and coexist safely in /tmp.
# NOTE: SCRIPT_DIR was verified not to contain " earlier in this script
VARS_PROFILE_CONTENT="(define SCRIPT_DIR \"${SCRIPT_DIR}\")"
VARS_PROFILE_CONTENT_HASH="$(echo "$VARS_PROFILE_CONTENT" | shasum -a 256 | awk '{print $1}')"
VARS_PROFILE="/tmp/gvc-sandbox-vars-${VARS_PROFILE_CONTENT_HASH}.sb"
echo "$VARS_PROFILE_CONTENT" > "$VARS_PROFILE"

# NOTE: --env-pass PATH enables locating short command names
SAFEHOUSE_COMMON_ARGS=(
    --workdir "$SCRIPT_DIR"
    --enable=macos-gui
    --env-pass=GVC_SEATBELT_SANDBOX,PATH
    --append-profile="$VARS_PROFILE"
    --append-profile="$SCRIPT_DIR/gvc-safehouse-extensions.sb"
)

if [[ "${1:-}" == "--stdout" ]]; then
    # Output *.sb policy to stdout
    exec "$SAFEHOUSE_REAL" "${SAFEHOUSE_COMMON_ARGS[@]}" --stdout
else
    # Run command
    # NOTE: safehouse will dynamically add permissions based on the command name
    #       that is run. In particular Claude Code ("claude") will add the
    #       60-agents/claude-code.sb profile.
    exec "$SAFEHOUSE_REAL" "${SAFEHOUSE_COMMON_ARGS[@]}" -- "$@"
fi
